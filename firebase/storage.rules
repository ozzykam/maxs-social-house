rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Media uploads (images/video) for the public site.
    match /media/{allPaths=**} {
      allow read: if true; // public site serves these
      allow write: if request.auth != null
        && 'permissions' in request.auth.token
        && 'cms:media' in request.auth.token.permissions
        && request.resource.size < 50 * 1024 * 1024 // 50MB cap
        && request.resource.contentType.matches('image/.*|video/.*');
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
